<h1>New Event</h1>

<%= form_with model: @event do |f| %>
<div>
    <%= f.label :name %><br>
    <%= f.text_field :name %>
</div>
<div>
    <%= f.label :location %> <br>
    <%= f.text_field :location %>
</div>
<div>
    <%= f.label :date %> <br>
    <%= f.date_field :date %>
</div>
<%= f.submit "Create Event" %>
<% end %>